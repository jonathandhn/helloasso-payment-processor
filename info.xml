<?xml version="1.0"?>
<extension key="helloasso-payment-processor" type="module">
  <file>helloasso_payment_processor</file>
  <name>helloasso-payment-processor</name>
  <description>HelloAsso online payments, authorization-screen connections, secure webhooks and payment reconciliation.</description>
  <license>AGPL-3.0</license>
  <maintainer>
    <author>Antoine BREHERET</author>
    <email>breheret@makoa.fr</email>
  </maintainer>
  <maintainer>
    <author>Jonathan Dahan</author>
    <email>jonathan@dhn.one</email>
  </maintainer>
  <urls>
    <url desc="Main Extension Page">https://lab.civicrm.org/extensions/helloasso-payment-processor</url>
    <url desc="Documentation">https://lab.civicrm.org/extensions/helloasso-payment-processor</url>
    <url desc="Support">https://lab.civicrm.org/extensions/helloasso-payment-processor/issues</url>
    <url desc="Licensing">http://www.gnu.org/licenses/agpl-3.0.html</url>
  </urls>
  <releaseDate>2026-06-03</releaseDate>
  <version>2.0.13</version>
  <develStage>stable</develStage>
  <compatibility>
    <ver>6.14</ver>
  </compatibility>
  <php_compatibility>
    <ver>8.0</ver>
    <ver>8.1</ver>
    <ver>8.2</ver>
    <ver>8.3</ver>
    <ver>8.4</ver>
  </php_compatibility>
  <smarty_compatibility>
    <ver>5</ver>
  </smarty_compatibility>
  <requires>
    <ext>civi_contribute</ext>
    <ext>mjwshared</ext>
  </requires>
  <comments>This is a Payment Processor for HelloAsso. Version 2 development and multi-CMS validation by Jonathan Dahan.</comments>
  <classloader>
    <psr0 prefix="CRM_" path="."/>
    <psr4 prefix="Civi\" path="Civi"/>
  </classloader>
  <civix>
    <namespace>CRM/HelloassoPaymentProcessor</namespace>
    <format>23.02.1</format>
    <angularModule>crmHelloassoPaymentProcessor</angularModule>
  </civix>
  <mixins>
    <mixin>menu-xml@1.0.0</mixin>
    <mixin>mgd-php@1.0.0</mixin>
    <mixin>setting-php@1.0.0</mixin>
    <mixin>smarty-v2@1.0.1</mixin>
    <mixin>entity-types-php@1.0.0</mixin>
    <mixin>scan-classes@1.0.0</mixin>
  </mixins>
  <upgrader>CRM_HelloassoPaymentProcessor_Upgrader</upgrader>
</extension>
