#. Public-facing string in checkout or validation flow
msgid "First name and last name must not be identical (HelloAsso rule)."
msgstr "El nombre y el apellido no deben ser idénticos (regla HelloAsso)."

#. Public-facing string in checkout or validation flow
msgid "Online contribution"
msgstr "Contribución en línea"

#. Public-facing string in checkout or validation flow
msgid "Online contribution: %1"
msgstr "Contribución en línea: %1"

#. Public-facing string in checkout or validation flow
msgid "The %1 contains unauthorized characters (HelloAsso rule)."
msgstr "El %1 contiene caracteres no permitidos (regla HelloAsso)."

#. Public-facing string in checkout or validation flow
msgid "The %1 must contain at least 3 characters (HelloAsso rule)."
msgstr "El %1 debe contener al menos 3 caracteres (regla HelloAsso)."

#. Public-facing string in checkout or validation flow
msgid "The %1 must contain at least one vowel (HelloAsso rule)."
msgstr "El %1 debe contener al menos una vocal (regla HelloAsso)."

#. Public-facing string in checkout or validation flow
msgid "The %1 must not contain 3 repeated characters (HelloAsso rule)."
msgstr "El %1 no debe contener 3 caracteres repetitivos (regla HelloAsso)."

#. Public-facing string in checkout or validation flow
msgid "The %1 must not contain numbers (HelloAsso rule)."
msgstr "El %1 no debe contener números (regla HelloAsso)."

#. Public-facing string in checkout or validation flow
msgid "The value of %1 is not allowed by HelloAsso."
msgstr "El valor de %1 no está permitido por HelloAsso."

#. Public-facing string in checkout or validation flow
msgid "You will be redirected to HelloAsso to complete your payment."
msgstr "Será redirigido a HelloAsso para realizar el pago."

