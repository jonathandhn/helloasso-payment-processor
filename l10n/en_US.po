#. Public-facing string in checkout or validation flow
msgid "Contribution en ligne"
msgstr "Online contribution"

#. Public-facing string in checkout or validation flow
msgid "Contribution en ligne : %1"
msgstr "Online contribution: %1"

#. Public-facing string in checkout or validation flow
msgid "La valeur du %1 n'est pas autorisée par HelloAsso."
msgstr "The value of %1 is not allowed by HelloAsso."

#. Public-facing string in checkout or validation flow
msgid "Le %1 contient des caractères non autorisés (règle HelloAsso)."
msgstr "The %1 contains unauthorized characters (HelloAsso rule)."

#. Public-facing string in checkout or validation flow
msgid "Le %1 doit contenir au moins 3 caractères (règle HelloAsso)."
msgstr "The %1 must contain at least 3 characters (HelloAsso rule)."

#. Public-facing string in checkout or validation flow
msgid "Le %1 doit contenir au moins une voyelle (règle HelloAsso)."
msgstr "The %1 must contain at least one vowel (HelloAsso rule)."

#. Public-facing string in checkout or validation flow
msgid "Le %1 ne doit pas contenir 3 caractères répétitifs (règle HelloAsso)."
msgstr "The %1 must not contain 3 repetitive characters (HelloAsso rule)."

#. Public-facing string in checkout or validation flow
msgid "Le %1 ne doit pas contenir de chiffres (règle HelloAsso)."
msgstr "The %1 must not contain numbers (HelloAsso rule)."

#. Public-facing string in checkout or validation flow
msgid "Le nom et le prénom ne doivent pas être identiques (règle HelloAsso)."
msgstr "First name and last name must not be identical (HelloAsso rule)."

#. Public-facing string in checkout or validation flow
msgid "Vous serez redirigé vers HelloAsso pour effectuer le paiement."
msgstr "You will be redirected to HelloAsso to complete your payment."

